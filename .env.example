# Analytics Environment Variables
# Set these in Vercel Dashboard → Settings → Environment Variables

# Upstash Redis REST API URL (from upstash.com console)
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io

# Upstash Redis REST API Token
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# Secret key to access analytics dashboard
# Choose any strong random string — you'll use this to unlock /analytics.html
ANALYTICS_SECRET=your-secret-key-here

# Optional: Salt for IP hashing (defaults to 'sb-portal-analytics' if not set)
# ANALYTICS_SALT=custom-salt
